# LocalStack Configuration
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
LOCALSTACK_ENDPOINT=http://localhost:4566

# Application Settings
LOG_LEVEL=INFO
ENABLE_DEBUG=false

# Storage Configuration
WORKOUT_BUCKET=runctl-workouts
TEMPLATE_BUCKET=runctl-templates

# Garmin Connect API Configuration
GARMIN_EMAIL=your.email@example.com
GARMIN_PASSWORD=your_password
GARMIN_API_BASE_URL=https://connect.garmin.com/modern

# Monitoring Configuration
MONITORING_METRICS_ENABLED=true
MONITORING_METRICS_PUSH_GATEWAY_URL=http://localhost:9091
MONITORING_METRICS_COLLECTION_INTERVAL_SECONDS=15

MONITORING_HEALTH_CHECKS_ENABLED=true
MONITORING_HEALTH_CHECKS_CHECK_INTERVAL_SECONDS=30
MONITORING_HEALTH_CHECKS_ENDPOINTS='{"redis": true, "garmin": true, "rate_limits": true}'
MONITORING_HEALTH_CHECKS_API_KEY=your_monitoring_api_key  # Change this in production

MONITORING_ALERT_THRESHOLDS_ERROR_RATE=0.05
MONITORING_ALERT_THRESHOLDS_CACHE_MISS_RATE=0.20
MONITORING_ALERT_THRESHOLDS_API_LATENCY_SECONDS=2.0
MONITORING_ALERT_THRESHOLDS_RATE_LIMIT_BUFFER=0.80

# Alert Notification Configuration
MONITORING_ALERT_EMAIL_ADDRESSES=alerts@example.com,oncall@example.com
MONITORING_ALERT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
MONITORING_ALERT_SLACK_CHANNEL=#runctl-alerts
MONITORING_ALERT_SLACK_ONCALL_USERS=@user1,@user2
